---
/**
 * @component Banner
 * @description A banner component that has a background image and a content section. Usually placed on top of a page.    
 * @prop {string} bg - The background image URL for the banner. Optional.
 * 
 * @note As of now, relative paths must have "import.meta.env.BASE_URL" at the start of the path/URL.
 *        This is due to hosting sometimes being confused with URLs and paths. Refer to examples from 
 *        the pages files.
 */

interface Props {
    bg?: string;
}
const { bg } = Astro.props;

const backgroundStyle = bg ? `--bg-image: url('${bg}')` : undefined;
---
<div class='banner-container' style={backgroundStyle}>
    <div class="banner">
        <div class="banner-content">
            <slot name="heading"/>
            <slot name="text"/>
        </div>
    </div>
</div>

<style>
    .banner-container {
        position: relative;
        display: flex;
        background-color: var(--color-bg-primary-transparent);
        padding-block: 6vw 3vw;
      
        &::before {
            content: '';
            position: absolute;
            inset: 0;
            background: inherit;
            z-index: -1;
            background-image: var(--bg-image);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* -- BANNER SECTION */
        .banner {
            width: 100%;
            padding-top: 3rem;
            padding-inline: 15vw;
            display: flex;
            flex-direction: column;
            justify-content: center;
            margin: auto;
            gap: 3rem;
            color: white;
        }
        
        /* -- BANNER SECTION BODY */
        .banner-content {
            width: 45ch;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }
    } 
</style>