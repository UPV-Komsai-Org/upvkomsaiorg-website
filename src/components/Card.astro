---
import Link from "./Link.astro"
---
<div class="card-container">
    <figure><img src={`${import.meta.env.BASE_URL}/assets/komsai-banner-2.jpg`}></figure>
    <h3>Lorem Ipsum Dolor Sit Amet Constetuar </h3>
    <p>06 June</p>
    <p>Regular technical workshops on modern tools and core programming foundations.</p>
    <div class="call-to-action bold"><Link href="/" name="See More" mode="accent"></div>
</div>

<style>
    .card-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .card-container figure {
        width: 100%;
    }
    .card-container figure img {
        width: inherit;
    }
    .call-to-action {
        display: flex;
        justify-content: flex-end;
    }
</style>