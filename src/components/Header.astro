---
import './../global.css';
import { href } from "./../state";

interface Route {
    link: string;
    name: string;
}
const routes: Route[] = [
    {
        "link": `${import.meta.env.BASE_URL}/`,
        "name": "Home"
    },
    {
        "link": `${import.meta.env.BASE_URL}/about`,
        "name": "About Us"
    }, 
    {
        "link": `${import.meta.env.BASE_URL}/news`,
        "name": "News"
    }, 
    {
        "link": `${import.meta.env.BASE_URL}/events`,
        "name": "Events"
    }
]
---

<header class="header">
    <figure class="logo">
        <img src={`${import.meta.env.BASE_URL}/assets/komsai-logo.png`}/>
        <div class="logo-name">
            <h4>UPV</h4>
            <h4><strong>KOMSAI.ORG</strong></h4>
        </div>
    </figure>
    <div class="navbar-container">
        <!-- <figure class="hamburger"><img src=`${import.meta.env.BASE_URL}/assets/hamburger.png`/></figure> -->
        <nav class="navbar">
            <!-- <figure class="close-button hidden"><img src=`${import.meta.env.BASE_URL}/assets/close.png`/></figure> -->
            {
                routes.map(route => (
                    <a href={route.link} class={`navlink ${ (href.get() === route.link) && 'active-link'} `}> {route.name} </a>
                ))
            }
        </nav>
    </div>
    <script>
        const navbar = document.querySelector(".nav-container .navbar")!;
        const hamburgerButton = document.querySelector(".nav-container .hamburger")!;
        const closeButton = document.querySelector(".nav-container .close-button")!;

        function toggleMenu(isOpen: boolean) {
            if (isOpen) {
                navbar.classList.add("is-open");
                hamburgerButton.classList.add("hidden");
                closeButton.classList.remove("hidden");
            } else {
                navbar.classList.remove("is-open");
                hamburgerButton.classList.remove("hidden");
                closeButton.classList.add("hidden");
            }
        }
        hamburgerButton.addEventListener("click", () => toggleMenu(true));
        closeButton.addEventListener("click", () => toggleMenu(false));
        window.matchMedia('(min-width : 576px)').addEventListener("change", () => toggleMenu(false));
    </script>
</header>
<style>
    .header {
        width: 1200px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 1rem;
    }
    .header .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .header .logo img {
        width: 70px;
        height: 70px;
    }
    .navbar {
        display: flex;
        justify-content: space-between;
    }
    .navbar .navlink {
        padding-bottom: 0.5rem;
        margin: 1.5rem;
        color: white;
        font-weight: bold;
    }
    .navbar .navlink.active-link {
        border-bottom: solid 3px var(--color-accent);
    }
    
</style>

