---
/**
 * @component Footer
 * @description The Footer is the UI component found at the bottom of the page. It includes the logo, quick links, and other information about the organization. 
 *              It is a global component that is used in all pages.
 * @note As of now, relative paths must have "import.meta.env.BASE_URL" at the start of the path/URL.
 */
---
<footer class="footer">
    <div class="footer-logo">
        <img src={`${import.meta.env.BASE_URL}/assets/logos/komsai-dark-mode.png`}/>
        <h4 class="bold">UPV KOMSAI.ORG</h4>
    </div>    
    <nav>
        <a href={`${import.meta.env.BASE_URL}/`}>Home</a>
        <a href={`${import.meta.env.BASE_URL}/events`}>News</a>
        <a href={`${import.meta.env.BASE_URL}/news`}>Events</a>
        <a href={`${import.meta.env.BASE_URL}/about`}>About Us</a>
    </nav>
    <div class="footer-info-section">
        <p>All Rights Reserved @ 2026</p>
        <p>College of Arts and Sciences | University of the Philippines Visayas</p>
        <p>Miagao, 5023</p>
        <div class="footer-socials">
            <a href="https://www.facebook.com/UPVKomsai.Org/"><img src={`${import.meta.env.BASE_URL}/assets/icons/facebook.png`}/></a>
            <a href="https://www.youtube.com/@upvkomsaiorg3517"><img src={`${import.meta.env.BASE_URL}/assets/icons/youtube.png`}/></a>
        </div>
    </div>
</footer>
<style>
    .footer {
        display: grid;
        grid-template-columns: 2fr 1fr 5fr;
        justify-content: space-between;
        gap: 3rem;
        padding-block: 3rem;
        padding-inline: 15vw;
        background-color: var(--color-bg-primary);
        color: white;

        @media screen and (max-width: 960px) {
            & {
                padding-inline: 5vw;
                gap: 2rem;
            }
        }

        @media screen and (max-width: 576px) {
            grid-template-columns: 1fr;
            gap: 4rem;
            justify-items: left;
            padding-block: 6rem;
        }
        
        /* -- FOOTER LOGO */
        .footer-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }
        .footer-logo img {
            width: 6rem;
        }
        
        /* -- FOOTER NAVIGATION */
        nav {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        nav a {
            color: white;
        }

        /* -- FOOTER INFO SECTIOn */
        .footer-info-section {
            display: flex;				
            flex-direction: column;
            gap: 0.5rem;
        }
        .footer-socials {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-block: 0.5rem;
        }
        .footer-socials img {
            width: 1.5rem;
        }
    }
</style>