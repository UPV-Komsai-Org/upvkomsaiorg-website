---
/**
 * @component Line
 * @description A simple line component that is used for decoration or accent.
 * @prop {width} width - The width of the line. It takes in the same syntax for Dimensions as normal CSS. Required.
 *                       Example: "67px, 6rem, 7ch, etc."
 * @note Line will always be colored as the accent color. See the CSS variable "--color-accent" for the color of the line in global.css
 * 
 */
interface Props {
    width: string;
}
const { width } = Astro.props
---

<hr class="line" style={`width: ${width};`}/>
<style>
    /* -- LINE */
    .line {
        border: solid 3px var(--color-accent);
        width: 4rem;
        margin-block: 0.5rem;
    }
</style>