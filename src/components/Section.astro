---
/**
 * @component Section
 * @description The Section component is a general-purpose UI component that can be used to create sections of a webpage.
 *              This is a general one-column UI component that contains a header, body, and a call to action.
 *              The body is a grid that can take in a single component or multiple elements in a row. The 
 *              number of columns in the grid can be specified by the "columns" prop.   
 * 
 * @prop {string} bg - The background image to be used in the section. Valid values for it are URLs of the image used.
 * @prop {number} columns - The number of columns in the grid. Default is 1. If more than 1 is specified, 
 *              the grid will be displayed in multiple columns.
 * 
 * @note As of now, relative paths must have "import.meta.env.BASE_URL" at the start of the path/URL.
 *        This is due to hosting sometimes being confused with URLs and paths. Refer to examples from 
 *        the pages files.
 */

interface Props {   
    bg?: string;
    columns?: number;
}
const { bg, columns } = Astro.props;

const backgroundStyle = bg ? `--bg-image: url('${bg}')` : null;
const columnStyle = columns ? `--columns: ${columns}` : null;
const combinedStyles = [backgroundStyle, columnStyle].filter(Boolean).join(';'); 
---
<section class='section-container' style={combinedStyles}>
    <slot name="heading"/>
    <div class="section-body">
        <slot name="body"/>
    </div>
    <div class="section-call-to-action">
        <slot name="call-to-action"/>
    </div>
</section>

<style>
    /* -- SECTION */
    .section-container {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
        gap: 3rem;
        padding-inline: 15vw;
        padding-block: 5rem;
    
        &::before {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0.07;
            background: inherit;
            z-index: -1;
            background-image: var(--bg-image);
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* SECTION BODY */
        .section-body > :global(*) {
            display: grid;
            grid-template-columns: repeat(var(--columns, 1), minmax(0, 1fr));
            gap: 2rem;
            padding-inline: 2vw;
        } 

        /* SECTION CALL TO ACTION */
        .section-call-to-action > :global(*) {
            display: flex;
            justify-content: center;
            margin-block: 1rem;
            
        }
    } 
</style>