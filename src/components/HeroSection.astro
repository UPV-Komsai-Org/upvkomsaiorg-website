---
import Header from './Header.astro'
const { bg } = Astro.props;
---

<section class="hero-section">
    <Header/>
    <div class="section">
        <div class="body">
            <div class="content">
                <slot name="heading"/>
                <slot name="text"/>
            </div>
            <div class="call-to-action">
                <slot name="call-to-action"/>
            </div>
        </div>    
        <div class="gap"></div>
        <figure>
            <slot name="image"/>
        </figure>
    </div>
</section>

<style>
    .hero-section {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: var(--color-primary);
        color: white;
        padding: 0rem 2rem;
    }
    .hero-section::before {
        content: "";
        width: inherit;
        height: inherit;
        left: inherit;
        position: absolute;
        inset: 0;
        z-index: -1;
        background-image: url('/assets/komsai-banner.jpg');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center center;
    }
    .hero-section .section {
        width: 960px;
        display: grid;
        grid-template-columns: 50ch auto 300px;
        padding-block: 5rem;
    }
    .hero-section .content {
        display: flex;
        flex-direction: column;
        gap: 2rem;  
        margin-bottom: 2rem    
    }
    .hero-section :global(.call-to-action > *) {
        height: inherit;
        display: flex;
        align-items: center;
        gap: 3rem;
    }
    .hero-section figure :global(img) {
        width: 100%;
        aspect-ratio: 1/1;
        object-fit: cover;
    }
</style>
