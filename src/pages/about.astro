---
import './../global.css';
import { Button, Card, Footer, HeroSection, Line, Media, Link, Navbar, Section } from './../components/Component';
import { href } from './../state';

href.set(`${import.meta.env.BASE_URL}/about`);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
		<title>About Komsai.Org</title>
	</head>
	<body>
		<Navbar/>
		<HeroSection bg={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}>
			<div slot="heading">
				<h2>About</h2>
				<h1>Komsai.Org</h1>
			</div>			
			<p slot="text">
				The official organization of Computer Science students at the University of the Philippines Visayas. We foster a community of builders and problem-solvers through technology, innovation, and academic excellence.
			<div slot="call-to-action">
				<Button 
					href={`${import.meta.env.BASE_URL}/docs/komsai-constitution-and-by-laws.pdf`} 
					download='komsai-constitution'
					name='Download Constitution' 
					mode="dark"
					icon={`${import.meta.env.BASE_URL}/assets/icons/download.png`}
					flow='reverse'
				/>
			</div>
		</HeroSection>
		<Section bg={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}>
			<div slot="heading">
				<h2 class="bold">Komsai Video</h2>
				<Line width='3rem'/>
				<p>Watch our featured video to learn more about our student community and our initiatives.</p>
			</div>
			<div slot="body">
				<iframe 
					width="100%" 
					height="600px" 
					loading="lazy" 
					src="https://www.youtube.com/embed/IFlVIDpWGUk"					
					title="YouTube video player" 
					allow="accelerometer; 
					autoplay; 
					clipboard-write; 
					encrypted-media; 
					gyroscope; 
					picture-in-picture" 
					allowfullscreen>
				</iframe>
			</div>
		</Section>
		<Section columns={3}>
			<div slot="heading">
				<h2 class="bold">Executive Committee</h2>
				<Line width='3rem'/>
			</div>
			<div slot="body">
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Workshop & Training"	
					text="Regular technical workshops on modern tools and core programming foundations."
				/>
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Competitions"	
					text="Join coding competitions and hackathons that sharpen practical skills."
				/>
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Community Projects"	
					text="Collaborate on impactful projects that serve students and local communities."
				/>
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Workshop & Training"	
					text="Regular technical workshops on modern tools and core programming foundations."
				/>
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Competitions"	
					text="Join coding competitions and hackathons that sharpen practical skills."
				/>
				<Card 
					img={`${import.meta.env.BASE_URL}/assets/banners/komsai-banner-2.jpg`}
					title="Community Projects"	
					text="Collaborate on impactful projects that serve students and local communities."
				/>
			</div>
		</Section>
		<Footer/>
	</body>
</html>
